FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}
dimensions      [0 2 -2 0 0 0 0];
internalField   uniform 0.00341;

boundaryField
{
    AMI1
    {
        type            cyclicAMI;
        value           uniform 0.00341;
    }

    AMI2
    {
        type            cyclicAMI;
        value           uniform 0.00341;
    }

    cone
    {
        type            kqRWallFunction;
        value           uniform 0.00341;
    }

    inlet
    {
        type            turbulentIntensityKineticEnergyInlet;
        intensity       0.05;
        value           uniform 0.00341;
    }

    outlet
    {
        type            zeroGradient;
    }

    walls
    {
        type            kqRWallFunction;
        value           uniform 0.00341;
    }

}
