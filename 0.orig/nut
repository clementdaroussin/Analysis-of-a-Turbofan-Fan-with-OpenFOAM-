FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nut;
}
dimensions      [0 2 -1 0 0 0 0];
internalField   uniform 1e-5;

boundaryField
{
    AMI1
    {
        type            cyclicAMI;
        value           uniform 1e-5;
    }

    AMI2
    {
        type            cyclicAMI;
        value           uniform 1e-5;
    }

    cone
    {
        type            nutkWallFunction;
        value           uniform 1e-5;
    }

    inlet
    {
        type            zeroGradient;
    }

    outlet
    {
        type            zeroGradient;
    }

    walls
    {
        type            nutkWallFunction;
        value           uniform 1e-5;
    }

}
